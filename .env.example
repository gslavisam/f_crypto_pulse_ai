# Copy this file to .env and fill in your keys
# cp .env.example .env

# ── AI Provider Selection ──────────────────────────────────────────────────────
# Choose one: openrouter | groq | lmstudio | openai | zai
ACTIVE_AI_PROVIDER=openrouter

# ── OpenRouter (recommended — free tier available, no credit card) ─────────────
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# ── Groq (fast inference, free tier) ─────────────────────────────────────────
# Get key at: https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama3-8b-8192

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── ZhipuAI (Z.AI) ───────────────────────────────────────────────────────────
ZAI_API_KEY=...

# ── LM Studio (fully local / offline) ────────────────────────────────────────
# Start LM Studio, load a model, enable local server on port 1234
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=local-model
LMSTUDIO_API_KEY=lm-studio
